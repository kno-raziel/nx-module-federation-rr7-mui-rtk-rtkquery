{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["development"],
    "baseUrl": ".",
    "paths": {
      "login/Module": ["apps/react/login/src/remote-entry.ts"],
      "login/ProtectedRoutes": [
        "apps/react/login/src/app/components/ProtectedRoutes.tsx"
      ],
      "store/Store": ["apps/react/store/src/app/store/index.ts"],
      "store/Hooks": ["apps/react/store/src/app/store/hooks.ts"],
      "store/WithAsyncSlice": [
        "apps/react/store/src/app/components/WithAsyncSlice.tsx"
      ],
      "theme/Module": ["apps/react/theme/src/remote-entry.ts"],
      "theme/Theme": ["apps/libs/theme/src/index.ts"]
    }
  }
}
